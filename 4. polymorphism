# Complete Interview Level Code

```cpp
#include <iostream>
using namespace std;

class Complex
{
private:
    int real;
    int imag;

public:

    // Default Constructor
    Complex()
    {
        real = 0;
        imag = 0;
    }

    // Parameterized Constructor
    Complex(int r, int i)
    {
        real = r;
        imag = i;
    }

    // Copy Constructor
    Complex(const Complex &obj)
    {
        real = obj.real;
        imag = obj.imag;
    }

    // Getter Functions
    int getReal() const
    {
        return real;
    }

    int getImag() const
    {
        return imag;
    }

    // Display Function
    void print() const
    {
        cout << real << " + " << imag << "i" << endl;
    }

    /*
        Operator Overloading

        c1 + c2

        becomes

        c1.operator+(c2)
    */

    Complex operator+(const Complex &obj) const
    {
        Complex temp;

        temp.real = this->real + obj.real;
        temp.imag = this->imag + obj.imag;

        return temp;
    }

    // Overload -
    Complex operator-(const Complex &obj) const
    {
        Complex temp;

        temp.real = real - obj.real;
        temp.imag = imag - obj.imag;

        return temp;
    }

    // Overload ==
    bool operator==(const Complex &obj) const
    {
        return (real == obj.real &&
                imag == obj.imag);
    }

    // Friend function for <<
    friend ostream& operator<<(ostream &out,
                               const Complex &obj);

    // Friend function for >>
    friend istream& operator>>(istream &in,
                               Complex &obj);
};

/*
    Stream Insertion Operator

    cout << c1;
*/

ostream& operator<<(ostream &out,
                    const Complex &obj)
{
    out << obj.real
        << " + "
        << obj.imag
        << "i";

    return out;
}

/*
    Stream Extraction Operator

    cin >> c1;
*/

istream& operator>>(istream &in,
                    Complex &obj)
{
    in >> obj.real >> obj.imag;

    return in;
}

int main()
{
    Complex c1(2, 3);
    Complex c2(4, 5);

    cout << "First Complex Number: "
         << c1 << endl;

    cout << "Second Complex Number: "
         << c2 << endl;

    Complex sum = c1 + c2;

    cout << "\nAfter Addition:\n";
    cout << sum << endl;

    Complex diff = c1 - c2;

    cout << "\nAfter Subtraction:\n";
    cout << diff << endl;

    if(c1 == c2)
        cout << "\nEqual\n";
    else
        cout << "\nNot Equal\n";

    return 0;
}
```

